# Tracked environment template for local and deployment-specific `.env` files.
# `docker-compose.yml` mirrors the same tracked defaults, but the sensitive values
# below are non-runnable placeholders and will fail startup validation until you
# replace them in your untracked `.env`.
DB_NAME=self_management
DB_USER=postgres
DB_PASSWORD=postgres
POSTGRES_HOST_PORT=55432
JWT_SECRET=REPLACE_WITH_A_STRONG_JWT_SECRET_BEFORE_DEPLOYMENT
CONNECTOR_SECRET_KEY=UkVQTEFDRV9XSVRIXzMyX0JZVEVfQUVTX0tFWV9OT1c=
INTERNAL_API_TOKEN=REPLACE_WITH_A_RANDOM_INTERNAL_API_TOKEN_NOW
AUTH_COOKIE_SECURE=true
APP_TIMEZONE=Asia/Shanghai
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NUXT_PUBLIC_API_MODE=http
NUXT_PUBLIC_API_BASE=https://api.example.com/api/v1
NUXT_API_BASE_INTERNAL=http://admin-api:8080/api/v1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
DBT_RUNNER_URL=http://dbt-runner:8090
ADMIN_API_INTERNAL_BASE_URL=http://admin-api:8080
GARMIN_MOCK_MODE=false
SYNC_WORKER_INTERNAL_BASE_URL=http://sync-worker:8081
SCHEDULER_POLL_SECONDS=15
